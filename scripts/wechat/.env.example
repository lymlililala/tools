# DeepSeek（聚类/合成/自评分用）—— 复制为同目录 .env 并填值（.env 已 gitignore）
DEEPSEEK_API_KEY=your_deepseek_key
# 可选
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 配图（可选，仅在 synthesize 用 --images 时需要）
# PEXELS_API_KEY=your_pexels_key
# UNSPLASH_ACCESS_KEY=your_unsplash_key

# Supabase 入库（采集落 tools_wx_sources、发布 upsert tools_articles）。
# 优先用项目根 .env 的 SUPABASE_SECRET_KEY（与 supabase-admin.mjs 共用）；
# 也可在此覆盖：
# SUPABASE_SECRET_KEY=sb_secret_xxx
